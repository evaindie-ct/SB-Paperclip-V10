{
  "name": "Industrial Director",
  "slug": "industrial-director",
  "role": "pm",
  "title": "Industrial Director",
  "reportsTo": "operations-coordinator",
  "paperclipReportsTo": "operations-coordinator",
  "capabilities": [
    "Own industrial execution: suppliers, factories, production planning, QC, customs, warehouse, procurement",
    "Protect cost, quality, lead time, and supplier reliability"
  ],
  "budgetMonthlyCents": 7500,
  "contextMode": "fat",
  "heartbeatSchedule": {
    "enabled": false,
    "intervalSec": 3600,
    "recommended": "Hourly or twice daily once stable"
  },
  "tools": [
    "file",
    "paperclip"
  ],
  "permissions": {
    "filesystem": {
      "read": [
        "companies/san-bernardo/**",
        "original/**",
        "docs/**"
      ],
      "write": []
    },
    "browser": false,
    "network": false,
    "shell": false,
    "git": false,
    "paperclipWrite": true,
    "requiresHumanApprovalFor": [
      "contracts",
      "payments",
      "factory commitments",
      "tax/legal filings",
      "public brand statements",
      "production orders",
      "customer refunds outside policy",
      "new paid subscriptions"
    ]
  },
  "source": {
    "originalManual": "original/san-bernardo-paperclip-final-clean-operating-manual-with-diagram-and-librarian.md",
    "instructionFile": "companies/san-bernardo/agents/industrial-director/instructions.md",
    "agentFile": "companies/san-bernardo/agents/industrial-director/AGENTS.md",
    "sourcePacks": [
      "A: Paperclip / agent operations / model configuration",
      "B: Textile / knitwear / product development",
      "C: Industrial / suppliers / factory / customs / production",
      "F: Finance / tax / inventory / billing",
      "H: Packaging / EPR / environmental packaging compliance"
    ]
  },
  "adapterType": "claude_local",
  "adapterConfig": {
    "command": "claude",
    "cwd": "${SAN_BERNARDO_PAPERCLIP_ROOT}",
    "instructionsFilePath": "${SAN_BERNARDO_PAPERCLIP_ROOT}/companies/san-bernardo/agents/industrial-director/instructions.md",
    "model": "claude-opus-4-7",
    "effort": "high",
    "chrome": false,
    "promptTemplate": "You are {{agent.name}}, Industrial Director for San Bernardo. Review assigned Paperclip tasks, use your instruction file, execute only within your scope, cite sources when researching, and report concrete next actions.",
    "maxTurnsPerRun": 80,
    "dangerouslySkipPermissions": false,
    "extraArgs": [],
    "env": {
      "ANTHROPIC_API_KEY": "${secrets.anthropic_key}"
    },
    "timeoutSec": 1800,
    "graceSec": 30
  },
  "businessRole": "industrial_director"
}
