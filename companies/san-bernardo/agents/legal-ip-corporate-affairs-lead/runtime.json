{
  "name": "Legal / IP / Corporate Affairs Lead",
  "slug": "legal-ip-corporate-affairs-lead",
  "role": "general",
  "title": "Legal / IP / Corporate Affairs Lead",
  "reportsTo": "operations-coordinator",
  "paperclipReportsTo": "operations-coordinator",
  "capabilities": [
    "Own trademark/IP tracking, corporate admin, contracts checklisting, legal-risk flags, privacy/compliance routing, and escalation to professional counsel"
  ],
  "budgetMonthlyCents": 6000,
  "contextMode": "fat",
  "heartbeatSchedule": {
    "enabled": false,
    "intervalSec": 86400,
    "recommended": "Daily/weekly monitoring depending on active deadlines"
  },
  "tools": [
    "file",
    "paperclip",
    "web"
  ],
  "permissions": {
    "filesystem": {
      "read": [
        "companies/san-bernardo/**",
        "original/**",
        "docs/**"
      ],
      "write": []
    },
    "browser": false,
    "network": true,
    "shell": false,
    "git": false,
    "paperclipWrite": true,
    "requiresHumanApprovalFor": [
      "contracts",
      "payments",
      "factory commitments",
      "tax/legal filings",
      "public brand statements",
      "production orders",
      "customer refunds outside policy",
      "new paid subscriptions"
    ]
  },
  "source": {
    "originalManual": "original/san-bernardo-paperclip-final-clean-operating-manual-with-diagram-and-librarian.md",
    "instructionFile": "companies/san-bernardo/agents/legal-ip-corporate-affairs-lead/instructions.md",
    "agentFile": "companies/san-bernardo/agents/legal-ip-corporate-affairs-lead/AGENTS.md",
    "sourcePacks": [
      "A: Paperclip / agent operations / model configuration",
      "F: Finance / tax / inventory / billing",
      "G: Legal / IP / privacy / corporate governance"
    ]
  },
  "adapterType": "claude_local",
  "adapterConfig": {
    "command": "claude",
    "cwd": "${SAN_BERNARDO_PAPERCLIP_ROOT}",
    "instructionsFilePath": "${SAN_BERNARDO_PAPERCLIP_ROOT}/companies/san-bernardo/agents/legal-ip-corporate-affairs-lead/instructions.md",
    "model": "claude-opus-4-7",
    "effort": "high",
    "chrome": false,
    "promptTemplate": "You are {{agent.name}}, Legal / IP / Corporate Affairs Lead for San Bernardo. Review assigned Paperclip tasks, use your instruction file, execute only within your scope, cite sources when researching, and report concrete next actions.",
    "maxTurnsPerRun": 50,
    "dangerouslySkipPermissions": false,
    "extraArgs": [],
    "env": {
      "ANTHROPIC_API_KEY": "${secrets.anthropic_key}"
    },
    "timeoutSec": 1200,
    "graceSec": 30
  },
  "businessRole": "legal_ip_corporate_affairs_lead"
}
