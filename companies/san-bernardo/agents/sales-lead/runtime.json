{
  "name": "Sales Lead",
  "slug": "sales-lead",
  "role": "cmo",
  "title": "Sales Lead",
  "reportsTo": "sales-director",
  "paperclipReportsTo": "sales-director",
  "capabilities": [
    "Own sales outreach, pipeline hygiene, account notes, objections, and follow-ups",
    "Produce clear sales actions and next-step trackers"
  ],
  "budgetMonthlyCents": 3500,
  "contextMode": "thin",
  "heartbeatSchedule": {
    "enabled": false,
    "intervalSec": 7200,
    "recommended": "On-demand or twice daily once stable"
  },
  "tools": [
    "browser",
    "file",
    "paperclip",
    "web"
  ],
  "permissions": {
    "filesystem": {
      "read": [
        "companies/san-bernardo/**",
        "original/**",
        "docs/**"
      ],
      "write": []
    },
    "browser": true,
    "network": true,
    "shell": false,
    "git": false,
    "paperclipWrite": true,
    "requiresHumanApprovalFor": [
      "contracts",
      "payments",
      "factory commitments",
      "tax/legal filings",
      "public brand statements",
      "production orders",
      "customer refunds outside policy",
      "new paid subscriptions"
    ]
  },
  "source": {
    "originalManual": "original/san-bernardo-paperclip-final-clean-operating-manual-with-diagram-and-librarian.md",
    "instructionFile": "companies/san-bernardo/agents/sales-lead/instructions.md",
    "agentFile": "companies/san-bernardo/agents/sales-lead/AGENTS.md",
    "sourcePacks": [
      "A: Paperclip / agent operations / model configuration",
      "D: Ecommerce / catalog / customer service / customer data",
      "E: Sales / market / wholesale / commercial research",
      "F: Finance / tax / inventory / billing"
    ]
  },
  "adapterType": "claude_local",
  "adapterConfig": {
    "command": "claude",
    "cwd": "${SAN_BERNARDO_PAPERCLIP_ROOT}",
    "instructionsFilePath": "${SAN_BERNARDO_PAPERCLIP_ROOT}/companies/san-bernardo/agents/sales-lead/instructions.md",
    "model": "claude-sonnet-4-6",
    "effort": "medium",
    "chrome": true,
    "promptTemplate": "You are {{agent.name}}, Sales Lead for San Bernardo. Review assigned Paperclip tasks, use your instruction file, execute only within your scope, cite sources when researching, and report concrete next actions.",
    "maxTurnsPerRun": 50,
    "dangerouslySkipPermissions": false,
    "extraArgs": [],
    "env": {
      "ANTHROPIC_API_KEY": "${secrets.anthropic_key}"
    },
    "timeoutSec": 1200,
    "graceSec": 30
  },
  "businessRole": "sales_lead"
}
