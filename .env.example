# Paperclip local API
PAPERCLIP_API_BASE=http://localhost:3100/api

# Absolute local path after unzip
SAN_BERNARDO_PAPERCLIP_ROOT=/absolute/path/to/san-bernardo-paperclip-global-PAPERCLIP-RUNTIME-v10

# Company name to create/discover. Paperclip assigns the actual ID at runtime.
PAPERCLIP_COMPANY_NAME=San Bernardo

# Optional API token if your Paperclip instance uses bearer auth.
PAPERCLIP_AUTH_TOKEN=

# If hierarchy repair returns 401/403, paste your logged-in Paperclip browser cookie here.
# Browser DevTools -> Network -> any successful /api request -> Request Headers -> Cookie
PAPERCLIP_COOKIE=
PAPERCLIP_COOKIE_FILE=
PAPERCLIP_CSRF_TOKEN=

# LLM keys if using API-backed CLI adapters
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional browser/cloud services
BROWSER_USE_API_KEY=
OPENROUTER_API_KEY=

# Optional Hermes
HERMES_CONFIG_PATH=~/.hermes/config.yaml
PAPERCLIP_COMPANY_DESCRIPTION=Knitwear fashion brand business
